# =============================================================================
# APEX Autopilot — .gitignore
# =============================================================================

# --- Secrets (never commit) ---
.env
.env.*
!.env.example
keys.env
keys.env.*
*keys.env*
!keys.env.example
!**/.env.example
!**/*.env.example
*.pem
*.key
credentials.json
secrets/
*.secret
*.secrets
.env.backup
.env.bak
.env.local
autopilot-local/.env*
!autopilot-local/.env.*.example
autopilot-local/frontend/.env.local

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
*.egg
*.egg-info/
.eggs/

# --- Stale / debug files ---
scratch.py
scratch_*.py
*.debug.py

# --- Dynamic artifacts (regenerated each cycle; git noise) ---
artifacts/submission/*.json

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Build outputs ---
dist/
build/
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
node_modules/
.next/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- Playwright test artifacts ---
test-results/
*.trace.zip
*.zip

# --- TypeScript build artifacts ---
*.tsbuildinfo

# --- Log files ---
logs/*.log

# --- Model candidates (regenerated each cycle) ---
data/models/arb_edge/candidate_*/
