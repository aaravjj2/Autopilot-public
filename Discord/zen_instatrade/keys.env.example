# Discord Zen Instatrade - Keys Template
# Copy this file to keys.env and fill in your actual keys

# Discord Bot Token (self-bot token from Discord developer portal)
DISCORD_USER_TOKEN=your_discord_user_token_here

# Discord Bullseye Channel ID (the channel to monitor for signals)
DISCORD_BULLSEYE_CHANNEL_ID=your_channel_id_here

# Alpaca Paper Trading Keys (Discord-specific)
ALPACA_PAPER_KEY=your_alpaca_paper_key_here
ALPACA_PAPER_SECRET=your_alpaca_paper_secret_here
ALPACA_PAPER_URL=https://paper-api.alpaca.markets
