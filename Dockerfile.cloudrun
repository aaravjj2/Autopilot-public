# APEX Autopilot — production backend image for Google Cloud Run
# Build:  gcloud builds submit --tag <IMAGE>
# Run:    listens on $PORT (Cloud Run injects it), defaults to 8080 locally.
FROM python:3.11-slim AS base

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    APEX_HOME=/app

WORKDIR /app

# --- System deps (curl for healthcheck; build tools only during install) ---
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl build-essential \
    && rm -rf /var/lib/apt/lists/*

# --- Python deps: install core project deps first for layer caching ---
COPY pyproject.toml ./
# Install the declared core dependencies (without the package itself yet) plus
# the runtime soft-deps the backend needs in production.
RUN pip install \
      "apscheduler>=3.10.4,<4" "cryptography>=42.0,<43" "bcrypt>=4.1,<6" "pyjwt>=2.8,<3" \
      "pydantic>=2.8,<3" "pydantic-settings>=2.3,<3" "pandas>=2.2,<3" "numpy>=2.0,<3" \
      "requests>=2.32,<3" "starlette>=0.45,<2" "yfinance>=0.2.61,<1" "python-dateutil>=2.9,<3" \
      "uvicorn>=0.27,<1" "httpx>=0.27,<1" "fastapi>=0.110,<1" "transitions>=0.9,<1" \
      "prometheus-client>=0.20,<1" "reportlab>=4.0,<5" "websockets>=12.0,<14" "jsonpatch>=1.33,<2" \
      "redis>=5.0,<6" "chromadb>=0.5,<0.6" "openai>=1.30,<2" \
      "sqlmodel>=0.0.22,<1" "sse-starlette>=2.1,<3" "python-dotenv>=1.0,<2"

# --- Application source ---
COPY src/ ./src/
COPY agent/ ./agent/
COPY autopilot-local/backend/ ./autopilot-local/backend/
COPY backend_api.py ./

# marketplace_integration / marketplace_lifecycle live under autopilot-local/backend,
# apex package under src. Make all importable.
ENV PYTHONPATH=/app/src:/app/autopilot-local/backend:/app

# Cloud Run sets PORT; default 8080 for local runs.
ENV PORT=8080
EXPOSE 8080

# Runtime data dir (ephemeral on Cloud Run — auth/secrets DB should use a
# mounted volume or Cloud SQL in real prod; see SECURITY.md).
RUN mkdir -p /app/data

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD curl -fsS "http://localhost:${PORT}/health" || exit 1

# Single worker: the app runs in-process background loops + WS; multiple workers
# would duplicate schedulers. Scale horizontally via Cloud Run instances instead.
CMD exec uvicorn backend_api:app --host 0.0.0.0 --port "${PORT}" --workers 1
