# Copy to keys.env and fill in real values. Never commit keys.env.
# Used by APEX engine and scripts/sync-copy-trading-env.sh

TIINGO_API_KEY=your_api_key_here
FINAGE_API_KEY=your_api_key_here
NEWS_API_KEY=your_api_key_here
FINNHUB_API_KEY=your_api_key_here
FINNHUB2_API_KEY=your_api_key_here
X_API_BEARER=your_bearer_token_here
POLYGON_API_KEY=your_api_key_here
TWELVEDATA_API_KEY=your_api_key_here
QUANDL_API_KEY=your_api_key_here
PRIXIE_API_KEY=your_api_key_here

# Alpaca paper (primary)
APCA_API_KEY_ID=your_paper_key_id
APCA_API_SECRET_KEY=your_paper_secret
APCA_ENDPOINT=https://paper-api.alpaca.markets
APCA_EMERGENCY_KEY=your_emergency_key_here
OPTIONS_USE_ALPACA=1
OPTIONS_LAB_ALLOW_ALPACA=1

ALPACA2_KEY=your_api_key_here
ALPACA2_SECRET=your_api_secret_here
ALPACA_KEY_WEEKLY=${ALPACA2_KEY}
ALPACA_SECRET_WEEKLY=${ALPACA2_SECRET}
ALPACA_KEY_MONTHLY=${ALPACA2_KEY}
ALPACA_SECRET_MONTHLY=${ALPACA2_SECRET}

REDDIT_SECRET=your_secret_here
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_UID=your_username_here
REDDIT_PASSWORD=your_password_here

FRED_API_KEY=your_api_key_here
SEC_API_KEY=your_api_key_here
QUIVER_API_KEY=

POSTGRES_USER=dashboard_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=financial_dashboard
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

GROQ_API_KEY=your_api_key_here

ALPACA3_KEY=your_api_key_here
ALPACA3_SECRET=your_api_secret_here
ALPACA3_ENDPOINT=https://paper-api.alpaca.markets
STRATEGY_LAB_ALPACA_KEY=${ALPACA3_KEY}
STRATEGY_LAB_ALPACA_SECRET=${ALPACA3_SECRET}

LLM_PROVIDER=ollama
