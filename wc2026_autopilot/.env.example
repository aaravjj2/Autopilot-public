# Loads parent Autopilot keys.env + .env automatically when present.

# LLM brain: auto | groq | gemini | openrouter | ollama | anthropic | shell
WC_LLM_BRAIN=auto

# Optional explicit keys (usually set in ../keys.env)
GROQ_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_KEY=
ANTHROPIC_API_KEY=
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Shell terminal brain — pipes prompt to stdin of this command
# Example: ollama run llama3.2:3b
WC_SHELL_BRAIN_CMD=ollama run llama3.2:3b

# Optional football-data.org (10 req/min)
FOOTBALL_DATA_API_KEY=

# Optional live trading (read-only market fetch needs no keys)
KALSHI_API_KEY=
POLYMARKET_PRIVATE_KEY=

# Autopilot config
BANKROLL=1000
MIN_EDGE_THRESHOLD=0.05
MAX_KELLY_FRACTION=0.05
MIN_MARKET_VOLUME=1000
DRY_RUN=true
LOG_LEVEL=INFO
LOOP_SLEEP_MINUTES=15
