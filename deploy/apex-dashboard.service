[Unit]
Description=APEX Dashboard (FastAPI)
Documentation=https://github.com/anomalyco/autopilot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=%(U)s
WorkingDirectory=/home/%(U)s/Autopilot/autopilot-local/backend
ExecStart=/home/%(U)s/miniconda3/bin/uvicorn main:app --host 0.0.0.0 --port 8787
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
