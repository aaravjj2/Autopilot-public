# APEX Autopilot Engine environment example
# Copy to .env and fill in real values. Do not commit secrets.

# -----------------------------------------------------------------------------
# External repository paths
# -----------------------------------------------------------------------------
TRADINGAGENTS_REPO_PATH=./external/TradingAgents
DEXTER_REPO_PATH=./external/dexter
ANTHROPIC_FINANCIAL_SERVICES_REPO_PATH=./external/financial-services
MIROFISH_REPO_PATH=./external/MiroFish
DAILY_STOCK_ANALYSIS_REPO_PATH=./external/daily_stock_analysis
KRONOS_REPO_PATH=./external/Kronos
POLYMARKET_REPO_PATH=./external/PolyMarket-MCP
WHITMORELABS_REPO_PATH=./external/polymarket-mcp-server
ALPACA_MCP_REPO_PATH=./external/alpaca-mcp-server

# -----------------------------------------------------------------------------
# Core system and storage
# -----------------------------------------------------------------------------
STRICT_INTEGRATIONS=false
DEMO_MODE=false
SHOWCASE_MODE=false
SHOWCASE_ARB_COUNT=100
SHOWCASE_PROPOSAL_COUNT=32
PUBLIC_DEMO_URL=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=INFO
STREAMLIT_PORT=8501
WATCHLIST_MAX_SIZE=50
CHROMADB_PATH=./data/chromadb
SQLITE_PATH=./data/audit.db

# -----------------------------------------------------------------------------
# Daily stock analysis
# -----------------------------------------------------------------------------
DAILY_STOCK_ANALYSIS_ENABLED=true
DAILY_STOCK_ANALYSIS_REGION=us
DAILY_STOCK_ANALYSIS_MARKET_REVIEW=true
DAILY_STOCK_ANALYSIS_STOCK_DIGEST=false
DAILY_STOCK_ANALYSIS_MAX_STOCKS=12
DAILY_STOCK_ANALYSIS_TIMEOUT_MARKET_SEC=300
DAILY_STOCK_ANALYSIS_TIMEOUT_STOCKS_SEC=900

# -----------------------------------------------------------------------------
# Weekly focus / earnings overrides
# -----------------------------------------------------------------------------
WEEKLY_FOCUS_ENABLED=true
WEEKLY_FOCUS_SYMBOLS=
WEEKLY_FOCUS_CONVICTION_BOOST=0.35
WEEKLY_FOCUS_RELAX_EARNINGS_BLACKOUT=true
WEEKLY_FOCUS_EARNINGS_SYMBOLS=NVDA
NVDA_EARNINGS_DATE=2026-05-20
NVDA_EARNINGS_WINDOW_DAYS=5
NVDA_EARNINGS_CONVICTION_BOOST=0.45

# -----------------------------------------------------------------------------
# LLM keys — autopilot picks the first available (see LLM_AUTO_ROUTING).
# Priority: Groq → Gemini → OpenRouter → Ollama (local backup).
# -----------------------------------------------------------------------------
GROQ_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GOOGLE_API_KEY=
OPENROUTER_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Authentication & secret-vault (see SECURITY.md). REQUIRED in production.
# Generate strong random values:  python -c "import secrets;print(secrets.token_urlsafe(48))"
# AUTH_ENABLED=true enforces login on mutating endpoints; reads stay public/guest.
# If APEX_AUTH_SECRET is unset the server uses an ephemeral key (dev only) and
# all tokens are invalidated on restart.
# -----------------------------------------------------------------------------
AUTH_ENABLED=false
APEX_AUTH_SECRET=
APEX_SECRETS_KEY=
ALLOW_OPEN_REGISTRATION=true
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
AUTH_RATE_LIMIT_PER_MIN=10
API_RATE_LIMIT_PER_MIN=120

# -----------------------------------------------------------------------------
# LLM auto-routing (recommended for unattended autopilot)
# -----------------------------------------------------------------------------
LLM_AUTO_ROUTING=true
LLM_PROVIDER=auto
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_QUICK_MODEL=llama-3.1-8b-instant
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
LLM_DEEP_THINK_MODEL=
LLM_QUICK_THINK_MODEL=llama3.2:1b

# -----------------------------------------------------------------------------
# Alpaca paper trading
# -----------------------------------------------------------------------------
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER_TRADE=true

# -----------------------------------------------------------------------------
# Tradier / options data
# -----------------------------------------------------------------------------
TRADIER_SANDBOX_TOKEN=
TRADIER_SANDBOX_ACCT=
TRADIER_BASE_URL=https://sandbox.tradier.com

# -----------------------------------------------------------------------------
# Risk parameters
# -----------------------------------------------------------------------------
MAX_POSITION_SIZE_PCT=5.0
MAX_SECTOR_PCT=25.0
DAILY_LOSS_LIMIT_PCT=3.0
MAX_OPEN_POSITIONS=20
OPTIONS_MAX_LOSS_PCT=2.0
CONVICTION_FLOOR=5.0
DEXTER_THRESHOLD=7.0
DEXTER_TRIGGER_CONVICTION=8.0
OPTIONS_TRADING_ENABLED=true
ALPACA_FLATTEN_OPTIONS_TO_EQUITY=false

# -----------------------------------------------------------------------------
# Trading behavior
# -----------------------------------------------------------------------------
AUTOTRADE_ALL_APPROVED=true
TOP_SYMBOLS_PER_DAY=5
INITIAL_ACCOUNT_EQUITY=100000.0

# -----------------------------------------------------------------------------
# Polymarket paper trading / discovery
# -----------------------------------------------------------------------------
POLYMARKET_PAPER_TRADING_ENABLED=true
POLYMARKET_AUTOMATED_EVENTS_ENABLED=true
PM_AGENTS_AUTOMATION_ENABLED=true
KALSHI_ARB_AUTOMATED_PAPER_ENABLED=true
KALSHI_ARB_MAX_AUTO_TRADES_PER_CYCLE=2
PM_AGENT_LOOP_INTERVAL_SEC=300
APEX_PM_AGENTS_LOOP=true
PM_AGENT_FAST_SCAN=true
KALSHI_AGENT_USE_CACHED_OPPS=true
KALSHI_SCAN_MAX_MARKETS_PER_CATEGORY=50
KALSHI_SCAN_MAX_ORDERBOOKS=80
KALSHI_SCAN_ORDERBOOK_CONCURRENCY=8
ARB_CACHED_MAX_AGE_HOURS=168
APEX_ARB_SCAN_LOOP=true
ARB_SCAN_WARM_L2=false

# -----------------------------------------------------------------------------
# FIFA World Cup 2026
# -----------------------------------------------------------------------------
WORLD_CUP_ENABLED=true
WORLD_CUP_MIN_VOLUME_24H=1000
WORLD_CUP_DISCOVERY_LIMIT=80
WORLD_CUP_MIN_MODEL_EDGE=0.03
WORLD_CUP_MAX_AUTO_TRADES_PER_CYCLE=3

# -----------------------------------------------------------------------------
# Self-improvement (arb edge model)
# -----------------------------------------------------------------------------
SELF_IMPROVEMENT_ENABLED=true
SELF_IMPROVEMENT_MIN_LABELED_SAMPLES=5
SELF_IMPROVEMENT_MIN_ACCURACY_GAIN=0.02
SELF_IMPROVEMENT_LOOP_INTERVAL_SEC=86400
APEX_SELF_IMPROVEMENT_LOOP=false
SELF_IMPROVEMENT_CYCLE_TIMEOUT_SEC=180

POLYMARKET_PAPER_BANKROLL_USD=10000
POLYMARKET_PAPER_MAX_ORDER_USD=500
POLYMARKET_PAPER_DEFAULT_STAKE_USD=50
POLYMARKET_PAPER_MAX_OPEN_POSITIONS=25
POLYMARKET_EVENT_DISCOVERY_LIMIT=20
POLYMARKET_EVENT_MIN_VOLUME_24H=50000
POLYMARKET_EVENT_MIN_EDGE=0.08
POLYMARKET_EVENT_POLICY=underdog_bins
POLYMARKET_TRAINING_EXPORT_PATH=./data/polymarket_training.jsonl
POLYMARKET_TRAINING_FETCH_LIMIT=200

# -----------------------------------------------------------------------------
# Copy trading / dashboard
# -----------------------------------------------------------------------------
COPY_TRADING_ENABLED=true
COPY_TRADING_API_URL=http://127.0.0.1:8000
COPY_TRADING_WEB_URL=http://127.0.0.1:3000
AUTOPILOT_LOCAL_PATH=./autopilot-local

# -----------------------------------------------------------------------------
# Optional API keys used by integrations and adapters
# Leave blank unless the corresponding feature is enabled.
# -----------------------------------------------------------------------------
TIINGO_API_KEY=
FINAGE_API_KEY=
NEWS_API_KEY=
FINNHUB_API_KEY=
FINNHUB2_API_KEY=
X_API_BEARER=
POLYGON_API_KEY=
TWELVEDATA_API_KEY=
QUANDL_API_KEY=
PRIXIE_API_KEY=
QUIVER_API_KEY=
SEC_API_KEY=
GROQ_API_KEY=
OPENROUTER_KEY=
OLLAMA_KEY=

# -----------------------------------------------------------------------------
# Kalshi auth
# Use a key id plus a private key file path; do not paste raw private keys here.
# -----------------------------------------------------------------------------
# API access key + RSA PEM (aliases: KALSHI_ACCESS_KEY, KALSHI_API_KEY_ID, KALSHI_PRIVATE_KEY)
KALSHI_API_KEY=
KALSHI_API_PRIVATE_KEY=
KALSHI_PRIVATE_KEY_PATH=./keys/kalshi_private_key.pem
# Demo (orders appear on Kalshi demo site): https://demo-api.kalshi.co/trade-api/v2
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2
# Set true to POST real orders to Kalshi Trade API (demo URL above); false = internal APEX paper only
KALSHI_DEMO_TRADING_ENABLED=false

# Arb detection thresholds
ARB_MIN_NET_EDGE=0.02
KALSHI_MIN_VOLUME_24H=5000.0

# -----------------------------------------------------------------------------
# Misc / defaults for local development
# -----------------------------------------------------------------------------
POSTGRES_USER=dashboard_user
POSTGRES_PASSWORD=
POSTGRES_DB=financial_dashboard
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
